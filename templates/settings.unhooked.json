{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "CLAUDE_CODE_ENABLE_TOKEN_USAGE_ATTACHMENT": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_PLAN_MODE_INTERVIEW_PHASE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_MOUSE_CLICKS": true
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "default"
  },
  "model": "opus",
  "enabledPlugins": {
    "instruction-management@agency": true,
    "agentic-eval@agency": true,
    "agency-development@agency": true,
    "github-scaffold@agency": true,
    "ember@agency": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agency": {
      "source": {
        "source": "github",
        "repo": "dotknewt/agency"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "xhigh",
  "advisorModel": "claude-opus-4-7",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "theme": "auto",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
