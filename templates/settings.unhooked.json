{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "effortLevel": "medium",
  "advisorModel": "claude-opus-4-7",
  "tui": "fullscreen",
  "theme": "auto",
  "respectGitignore": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "awaySummaryEnabled": false,
  "permissions": {
    "defaultMode": "default"
  },
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "CLAUDE_CODE_ENABLE_TOKEN_USAGE_ATTACHMENT": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_PLAN_MODE_INTERVIEW_PHASE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "extraKnownMarketplaces": {
    "dotknewt-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "dotknewt/agency"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "agentic-eval@dotknewt-claude-plugins": false,
    "ember@dotknewt-claude-plugins": true,
    "memory-management@dotknewt-claude-plugins": true,
    "agent-governance@dotknewt-claude-plugins": false,
    "agent-owasp-compliance@dotknewt-claude-plugins": true
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
