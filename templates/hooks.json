{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/session_start.py'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/user_prompt_submit.py'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/pre_tool_use.py'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/post_tool_use.py'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/stop.py'"
          }
        ]
      }
    ]
  }
}
