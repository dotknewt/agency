{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "effortLevel": "medium",
  "advisorModel": "claude-opus-4-7",
  "tui": "fullscreen",
  "theme": "auto",
  "respectGitignore": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "awaySummaryEnabled": false,
  "permissions": {
    "defaultMode": "default"
  },
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "CLAUDE_CODE_ENABLE_TOKEN_USAGE_ATTACHMENT": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_PLAN_MODE_INTERVIEW_PHASE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "extraKnownMarketplaces": {
    "agency": {
      "source": {
        "source": "github",
        "repo": "dotknewt/agency"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "agentic-eval@agency": false,
    "ember@agency": true,
    "instruction-management@agency": true,
    "agent-governance@agency": false,
    "agent-owasp-compliance@agency": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/session_start.py'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/user_prompt_submit.py'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/pre_tool_use.py'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/post_tool_use.py'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'PATH=${CLAUDE_PROJECT_DIR}/.venv/bin:$PATH python ${CLAUDE_PROJECT_DIR}/integrations/claude_code_hooks/stop.py'"
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
