{
  "description": "Nudge the user to run /revise-instructions when the session has touched many files.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/revise-instructions-nudge.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
